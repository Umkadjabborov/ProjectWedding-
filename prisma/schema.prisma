generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model BookingService {
  id           Int          @id @default(autoincrement())
  bookingId    String       @db.VarChar(50) @map("booking_id")
  serviceType  ServiceType  @map("service_type")
  serviceName  String       @db.VarChar(255) @map("service_name")
  price        BigInt
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("booking_services")
}

model Booking {
  id              String           @id @db.VarChar(50)
  hallId          String           @db.VarChar(50) @map("hall_id")
  userId          String           @db.VarChar(50) @map("user_id")
  bookingDate     DateTime         @db.Date @map("booking_date")
  guestCount      Int              @map("guest_count")
  totalPrice      BigInt           @map("total_price")
  advancePayment  BigInt           @map("advance_payment")
  status          BookingStatus    @default(UPCOMING)
  notes           String?
  createdAt       DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime         @default(now()) @db.Timestamptz(6) @map("updated_at")
  bookingServices BookingService[]
  hall            Hall             @relation(fields: [hallId], references: [id], onUpdate: NoAction)
  user            User             @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([hallId, bookingDate])
  @@index([bookingDate], map: "idx_bookings_date")
  @@index([hallId], map: "idx_bookings_hall")
  @@index([status], map: "idx_bookings_status")
  @@index([userId], map: "idx_bookings_user")
  @@map("bookings")
}

model Car {
  id         String   @id @db.VarChar(50)
  hallId     String   @db.VarChar(50) @map("hall_id")
  brand      String   @db.VarChar(255)
  price      BigInt
  imageUrl   String?  @db.VarChar(255) @map("image_url")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  hall       Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hallId], map: "idx_cars_hall")
  @@map("cars")
}

model HallImage {
  id         Int      @id @default(autoincrement())
  hallId     String   @db.VarChar(50) @map("hall_id")
  url        String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  hall       Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hallId], map: "idx_hall_images_hall")
  @@map("hall_images")
}

model Hall {
  id             String      @id @db.VarChar(50)
  name           String      @db.VarChar(255)
  district       String      @db.VarChar(100)
  address        String
  capacity       Int
  pricePerSeat   BigInt      @map("price_per_seat")
  phone          String      @db.VarChar(20)
  status         HallStatus  @default(PENDING)
  ownerId        String?     @db.VarChar(50) @map("owner_id")
  karnayEnabled  Boolean     @default(false) @map("karnay_available")
  karnayPrice    BigInt?     @map("karnay_price")
  createdAt      DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime    @default(now()) @db.Timestamptz(6) @map("updated_at")
  bookings       Booking[]
  cars           Car[]
  hallImages     HallImage[]
  owner          User?       @relation(fields: [ownerId], references: [id], onUpdate: NoAction)
  menuItems      MenuItem[]
  singers        Singer[]

  @@index([district], map: "idx_halls_district")
  @@index([ownerId], map: "idx_halls_owner")
  @@index([status], map: "idx_halls_status")
  @@map("halls")
}

model MenuItem {
  id         String   @id @db.VarChar(50)
  hallId     String   @db.VarChar(50) @map("hall_id")
  name       String   @db.VarChar(255)
  imageUrl   String?  @db.VarChar(255) @map("image_url")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  hall       Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hallId], map: "idx_menu_hall")
  @@map("menu_items")
}

model OtpCode {
  id         Int      @id @default(autoincrement())
  userId     String   @db.VarChar(50) @map("user_id")
  code       String   @db.Char(6)
  expiresAt  DateTime @db.Timestamptz(6) @map("expires_at")
  used       Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_otp_user")
  @@map("otp_codes")
}

model Singer {
  id         String   @id @db.VarChar(50)
  hallId     String   @db.VarChar(50) @map("hall_id")
  name       String   @db.VarChar(255)
  price      BigInt
  imageUrl   String?  @db.VarChar(255) @map("image_url")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  hall       Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hallId], map: "idx_singers_hall")
  @@map("singers")
}

model User {
  id          String      @id @db.VarChar(50)
  firstName   String      @db.VarChar(100) @map("first_name")
  lastName    String      @db.VarChar(100) @map("last_name")
  email       String      @unique @db.VarChar(255)
  username    String      @unique @db.VarChar(100)
  password    String      @db.VarChar(255)
  phone       String      @db.VarChar(20)
  role        UserRole    @default(USER)
  isVerified  Boolean     @default(false) @map("is_verified")
  createdAt   DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")
  bookings    Booking[]
  halls       Hall[]
  otpCodes    OtpCode[]

  @@map("users")
}

enum BookingStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum HallStatus {
  PENDING
  APPROVED
}

enum ServiceType {
  SINGER
  CAR
  KARNAY
}

enum UserRole {
  ADMIN
  OWNER
  USER
}
