// =============================================================
// FAYL: prisma/schema.prisma
// MAQSAD: Ma'lumotlar bazasi sxemasi — barcha jadvallar va
//         ularning o'zaro bog'liqliklari shu yerda aniqlanadi.
//         Prisma ORM bu faylni o'qib, PostgreSQL jadvallarini
//         avtomatik yaratadi va TypeScript turlarini generatsiya qiladi.
// =============================================================

// Prisma Client generatori — TypeScript uchun type-safe DB client yaratadi
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL ulanish sozlamalari — .env faylidan DATABASE_URL o'qiladi
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------
// ENUM: Foydalanuvchi rollari
// ADMIN  — barcha huquqlar
// OWNER  — faqat o'z zalini boshqaradi
// USER   — faqat bron qiladi
// ---------------------------------------------------------------
enum Role {
  ADMIN
  OWNER
  USER
}

// ---------------------------------------------------------------
// ENUM: Zal holati
// PENDING  — admin tasdiqlashini kutmoqda
// APPROVED — tasdiqlangan, foydalanuvchilarga ko'rinadi
// ---------------------------------------------------------------
enum HallStatus {
  PENDING
  APPROVED
}

// ---------------------------------------------------------------
// ENUM: Bron holati
// UPCOMING  — kelajakdagi bron
// COMPLETED — o'tib ketgan bron
// CANCELLED — bekor qilingan bron
// ---------------------------------------------------------------
enum BookingStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------
// ENUM: Qo'shimcha xizmat turlari
// SINGER — xonanda
// KARNAY — karnay-surnay
// MENU   — taom
// CAR    — mashina
// ---------------------------------------------------------------
enum ServiceType {
  SINGER
  KARNAY
  MENU
  CAR
}

// ---------------------------------------------------------------
// MODEL: User — foydalanuvchilar jadvali
// Barcha rollar (ADMIN, OWNER, USER) shu jadvalda saqlanadi
// ---------------------------------------------------------------
model User {
  id         String   @id @default(cuid())   // Unikal ID (cuid format)
  firstName  String                           // Ism
  lastName   String                           // Familiya
  email      String   @unique                 // Email (unikal)
  username   String   @unique                 // Username (unikal)
  password   String                           // Bcrypt bilan hash qilingan parol
  phone      String?                          // Telefon (ixtiyoriy)
  role       Role     @default(USER)          // Rol (default: USER)
  isVerified Boolean  @default(false)         // Email tasdiqlangan yoki yo'q
  createdAt  DateTime @default(now())         // Yaratilgan vaqt
  updatedAt  DateTime @updatedAt              // Yangilangan vaqt

  halls    Hall[]    // Bu foydalanuvchiga tegishli zallar (OWNER uchun)
  bookings Booking[] // Bu foydalanuvchi qilgan bronlar
  otps     OTP[]     // Bu foydalanuvchiga yuborilgan OTP kodlar
}

// ---------------------------------------------------------------
// MODEL: OTP — email tasdiqlash kodlari jadvali
// Ega birinchi marta kirganda 6 xonali kod yuboriladi
// ---------------------------------------------------------------
model OTP {
  id        String   @id @default(cuid())
  userId    String                          // Qaysi foydalanuvchiga tegishli
  code      String                          // 6 xonali raqamli kod
  expiresAt DateTime                        // Muddati tugash vaqti (5 daqiqa)
  used      Boolean  @default(false)        // Ishlatilgan yoki yo'q
  createdAt DateTime @default(now())

  // User o'chirilsa, uning OTP lari ham o'chadi
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------
// MODEL: Hall — to'yxonalar jadvali
// ---------------------------------------------------------------
model Hall {
  id           String     @id @default(cuid())
  name         String                           // Zal nomi
  images       String[]                         // Rasm URL lari massivi
  district     String                           // Toshkent tumani
  address      String                           // To'liq manzil
  latitude     Float?                           // GPS koordinatalar (optional)
  longitude    Float?                           // GPS koordinatalar (optional)
  capacity     Int                              // Necha kishi sig'adi
  pricePerSeat Float                            // Bir kishi uchun narx (so'm)
  phone        String                           // Zal telefon raqami
  status       HallStatus @default(PENDING)     // Holat (default: PENDING)
  ownerId      String                           // Egasi (User.id)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  owner     User                @relation(fields: [ownerId], references: [id])
  bookings  Booking[]           // Bu zalga qilingan bronlar
  services  AdditionalService[] // Karnay-surnay kabi xizmatlar
  singers   Singer[]            // Xonandalar
  cars      Car[]               // Mashinalar
  menuItems MenuItem[]          // Menyu elementlari
}

// ---------------------------------------------------------------
// MODEL: AdditionalService — qo'shimcha xizmatlar (asosan Karnay)
// ---------------------------------------------------------------
model AdditionalService {
  id     String      @id @default(cuid())
  hallId String
  name   String   // Xizmat nomi
  price  Float    // Narxi
  type   ServiceType // Turi (KARNAY, SINGER, va h.k.)

  // Zal o'chirilsa, xizmatlar ham o'chadi
  hall Hall @relation(fields: [hallId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------
// MODEL: Singer — xonandalar jadvali
// ---------------------------------------------------------------
model Singer {
  id     String @id @default(cuid())
  hallId String
  name   String  // Xonanda ismi
  price  Float   // Narxi
  image  String  // Rasm URL

  hall Hall @relation(fields: [hallId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------
// MODEL: Car — to'y mashinalar jadvali
// ---------------------------------------------------------------
model Car {
  id     String @id @default(cuid())
  hallId String
  brand  String  // Mashina markasi (Mercedes, BMW...)
  price  Float   // Narxi
  image  String  // Rasm URL

  hall Hall @relation(fields: [hallId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------
// MODEL: MenuItem — menyu elementlari jadvali
// ---------------------------------------------------------------
model MenuItem {
  id     String @id @default(cuid())
  hallId String
  name   String  // Taom nomi (Osh, Manti...)
  image  String  // Rasm URL

  hall Hall @relation(fields: [hallId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------
// MODEL: Booking — bronlar jadvali
// ---------------------------------------------------------------
model Booking {
  id               String        @id @default(cuid())
  hallId           String
  userId           String
  date             DateTime                          // Bron qilingan sana
  guestCount       Int                               // Mehmonlar soni
  totalPrice       Float                             // Jami narx
  advancePayment   Float                             // Avans (jami narxning 20%)
  status           BookingStatus @default(UPCOMING)  // Holat
  selectedServices Json          @default("[]")      // Tanlangan xizmatlar (JSON)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  hall Hall @relation(fields: [hallId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
